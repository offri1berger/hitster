{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Grafana Cloud Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": ""       }
  ],
  "title": "Backspin Maestro",
  "uid": "backspin-maestro",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["backspin-maestro"],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Rooms",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_rooms_active",
          "instant": true,
          "legendFormat": "rooms"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected Sockets",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_sockets_connected",
          "instant": true,
          "legendFormat": "sockets"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Queue Delayed",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_queue_delayed",
          "instant": true,
          "legendFormat": "delayed"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disconnect Grace Timers",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_disconnect_grace_timers",
          "instant": true,
          "legendFormat": "timers"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "backspin_maestro_queue_waiting",  "legendFormat": "waiting"  },
        { "expr": "backspin_maestro_queue_delayed",  "legendFormat": "delayed"  },
        { "expr": "backspin_maestro_queue_active",   "legendFormat": "active"   },
        { "expr": "backspin_maestro_queue_failed",   "legendFormat": "failed"   }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Job Completion Rate (per min)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (job_name) (rate(backspin_maestro_jobs_completed_total[5m])) * 60",
          "legendFormat": "{{job_name}} completed"
        },
        {
          "expr": "sum by (job_name) (rate(backspin_maestro_jobs_failed_total[5m])) * 60",
          "legendFormat": "{{job_name}} failed"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Job Duration (p50 / p95)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, job_name) (rate(backspin_maestro_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, job_name) (rate(backspin_maestro_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job_name}} p95"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 }, "unit": "s" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Deezer API (fetches / min)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(backspin_maestro_deezer_fetch_total{result='ok'}[5m]) * 60",
          "legendFormat": "ok"
        },
        {
          "expr": "rate(backspin_maestro_deezer_fetch_total{result='fail'}[5m]) * 60",
          "legendFormat": "fail"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Games Started (total)",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "backspin_maestro_games_started_total", "instant": true, "legendFormat": "games" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Players Joined (total)",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "backspin_maestro_players_joined_total", "instant": true, "legendFormat": "players" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Stalled Jobs (total)",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "backspin_maestro_jobs_stalled_total", "instant": true, "legendFormat": "stalled" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Handler Errors (total)",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(backspin_maestro_handler_errors_total)", "instant": true, "legendFormat": "errors" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Placements (correct vs incorrect / min)",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(backspin_maestro_placements_total{result='correct'}[5m]) * 60", "legendFormat": "correct" },
        { "expr": "rate(backspin_maestro_placements_total{result='incorrect'}[5m]) * 60", "legendFormat": "incorrect" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "incorrect" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Steals & Reconnects (/ min)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(backspin_maestro_steal_attempts_total{result='success'}[5m]) * 60", "legendFormat": "steal success" },
        { "expr": "rate(backspin_maestro_steal_attempts_total{result='fail'}[5m]) * 60", "legendFormat": "steal fail" },
        { "expr": "rate(backspin_maestro_reconnects_total[5m]) * 60", "legendFormat": "reconnects" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "steal fail" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Guess Accuracy (/ min)",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(backspin_maestro_guess_attempts_total{result='correct'}[5m]) * 60", "legendFormat": "correct" },
        { "expr": "rate(backspin_maestro_guess_attempts_total{result='incorrect'}[5m]) * 60", "legendFormat": "incorrect" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "incorrect" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Song Skips & Pool Exhaustion (/ min)",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(backspin_maestro_song_skips_total[5m]) * 60", "legendFormat": "skips" },
        { "expr": "rate(backspin_maestro_no_songs_left_total[5m]) * 60", "legendFormat": "no songs left" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "no songs left" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Rate Limit Hits (total)",
      "gridPos": { "x": 0, "y": 40, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(backspin_maestro_rate_limit_hits_total)", "instant": true, "legendFormat": "hits" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Invalid Payloads (total)",
      "gridPos": { "x": 6, "y": 40, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(backspin_maestro_invalid_payload_total)", "instant": true, "legendFormat": "invalid" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 19,
      "type": "bargauge",
      "title": "Players per Game (distribution)",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (le) (backspin_maestro_players_per_game_bucket)",
          "instant": true,
          "legendFormat": "{{le}} players"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 20,
      "type": "bargauge",
      "title": "Avatar Choices",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(20, backspin_maestro_avatar_chosen_total)",
          "instant": true,
          "legendFormat": "{{avatar}}"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Decade Filter Choices",
      "gridPos": { "x": 12, "y": 48, "w": 6, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_decade_filter_chosen_total",
          "instant": true,
          "legendFormat": "{{filter}}"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "cyan", "value": null }] } } }
    },
    {
      "id": 22,
      "type": "bargauge",
      "title": "Songs per Player Choices",
      "gridPos": { "x": 18, "y": 48, "w": 6, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "backspin_maestro_songs_per_player_chosen_total",
          "instant": true,
          "legendFormat": "{{count}} songs"
        }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    }
  ]
}
